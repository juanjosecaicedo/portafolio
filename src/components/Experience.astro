---
import { experience } from "../data/portfolio";
---

<section
  id="experience"
  class="reveal max-w-6xl mx-auto px-5 py-16 sm:px-8 sm:py-20 lg:px-16 lg:py-24"
>
  <div
    class="font-mono text-[13px] text-(--accent) tracking-wide uppercase mb-4"
  >
    Experiencia
  </div>
  <h2 class="text-[28px] sm:text-4xl font-bold tracking-tight mb-10 max-w-xl">
    Dónde he trabajado.
  </h2>
  <div class="flex flex-col">
    {
      experience.map((job) => (
        <div class="grid grid-cols-1 sm:grid-cols-[180px_1fr] gap-3 sm:gap-6 py-7 border-t border-stone-200">
          <div class="font-mono text-[13px] text-stone-400">{job.period}</div>
          <div>
            <div class="font-bold text-[17px] mb-1">
              {job.role}{" "}
              <span class="text-stone-400 font-medium">
                — {job.company}
              </span>
            </div>
            <div class="text-[14.5px] leading-relaxed text-stone-600">
              {job.description}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
