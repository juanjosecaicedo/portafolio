---
import { BookUser, FolderKanban } from "@lucide/astro";
---

<section
  id="top"
  class="reveal grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr] gap-8 lg:gap-16 items-center max-w-6xl mx-auto px-5 py-16 sm:px-8 sm:py-20 lg:px-16 lg:py-32"
>
  <div>
    <div class="font-mono text-sm text-(--accent) tracking-wide uppercase mb-5">
      Hola, soy Juan José
    </div>
    <h1
      class="text-[40px] sm:text-6xl lg:text-7xl leading-[1.04] font-extrabold tracking-tight mb-6"
    >
      Desarrollador<br />Full&nbsp;Stack
    </h1>
    <p
      class="text-base sm:text-lg leading-relaxed text-stone-600 max-w-xl mb-9"
    >
      Construyo productos web completos — de la interfaz al servidor — con foco
      en rendimiento, código mantenible y buena experiencia de usuario.
    </p>
    <div class="flex gap-4 flex-wrap">
      <a
        href="#projects"
        class="flex gap-2 items-center px-7 py-3.5 bg-stone-900 text-stone-50 rounded-sm font-semibold text-[15px] hover:opacity-90"
      >
        <FolderKanban size={18} /> Ver proyectos
      </a>
      <a
        href="#contact"
        class="flex gap-2 items-center px-7 py-3.5 bg-transparent text-stone-900 border border-stone-300 rounded-sm font-semibold text-[15px] hover:border-stone-400"
      >
        <BookUser size={18} /> Contactar
      </a>
    </div>
  </div>

  <div
    class="bg-stone-900 rounded-md p-6 font-mono text-[13px] text-stone-300 leading-loose shadow-[0_20px_50px_-20px_rgba(28,25,23,0.4)]"
  >
    <div class="flex gap-2 mb-4">
      <div class="w-[11px] h-[11px] rounded-full bg-red-600"></div>
      <div class="w-[11px] h-[11px] rounded-full bg-amber-500"></div>
      <div class="w-[11px] h-[11px] rounded-full bg-green-600"></div>
    </div>
    <div><span class="text-(--accent)">$</span> whoami</div>
    <div class="text-stone-50">juan-jose — full stack developer</div>
    <div class="mt-3"><span class="text-(--accent)">$</span> cat stack.txt</div>
    <div class="text-stone-50">
      Nextjs · Node · Laravel · PHP · MySQL · Astro
    </div>
    <div class="mt-3"><span class="text-(--accent)">$</span> status</div>
    <div class="text-stone-50">disponible para nuevos proyectos_</div>
  </div>
</section>
